{
	email {$CADDY_ACME_EMAIL}
}

(pos_api) {
	request_body {
		max_size 10MB
	}

	route {
		handle /health {
			uri replace /health /api/v1/health
			reverse_proxy {$CADDY_UPSTREAM} {
				transport http {
					dial_timeout 30s
					response_header_timeout 60s
					read_timeout 60s
					write_timeout 60s
				}
			}
		}

		rate_limit {
			zone public_api {
				key {remote_host}
				events {$CADDY_RATE_LIMIT_EVENTS:300}
				window {$CADDY_RATE_LIMIT_WINDOW:1m}
			}
		}

		handle_path /rustfs/* {
			reverse_proxy rustfs:9000 {
				header_up Host {upstream_hostport}
				transport http {
					dial_timeout 30s
					response_header_timeout 60s
					read_timeout 60s
					write_timeout 60s
				}
			}
		}

		handle {
			reverse_proxy {$CADDY_UPSTREAM} {
				transport http {
					dial_timeout 30s
					response_header_timeout 60s
					read_timeout 60s
					write_timeout 60s
				}
			}
		}
	}
}

