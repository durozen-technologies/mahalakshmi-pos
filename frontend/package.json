{
  "name": "frontend",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node ./scripts/cleanup-bundled-native-deps.js",
    "prestart": "node ./scripts/cleanup-bundled-native-deps.js",
    "start": "expo start",
    "prestart:go": "node ./scripts/cleanup-bundled-native-deps.js",
    "start:go": "expo start --go",
    "prestart:dev": "node ./scripts/cleanup-bundled-native-deps.js",
    "start:dev": "expo start --dev-client",
    "eas:configure": "npx eas-cli@latest build:configure",
    "eas:android:preview": "npx eas-cli@latest build -p android --profile preview",
    "eas:android:production": "npx eas-cli@latest build -p android --profile production",
    "eas:android:run": "npx eas-cli@latest build:run -p android --latest",
    "prestart:android": "node ./scripts/cleanup-bundled-native-deps.js",
    "start:android": "bash ./scripts/start-android-dev-client.sh",
    "doctor:android": "node ./scripts/check-android-env.js",
    "emulator:start": "bash ./scripts/start-android-emulator.sh",
    "preandroid:emu": "node ./scripts/cleanup-bundled-native-deps.js",
    "android:emu": "bash ./scripts/run-android-dev.sh",
    "reset-project": "node ./scripts/reset-project.js",
    "preandroid": "node ./scripts/cleanup-bundled-native-deps.js",
    "android": "expo run:android",
    "preandroid:usb": "node ./scripts/cleanup-bundled-native-deps.js",
    "android:usb": "bash ./scripts/run-android-usb.sh",
    "preandroid:dev": "node ./scripts/cleanup-bundled-native-deps.js",
    "android:dev": "bash ./scripts/run-android-dev.sh",
    "ios": "expo run:ios",
    "preweb": "node ./scripts/cleanup-bundled-native-deps.js",
    "web": "expo start --web",
    "lint": "eslint App.tsx src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@haroldtran/react-native-thermal-printer": "^1.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.14.12",
    "@tamagui/config": "^2.0.0",
    "axios": "^1.15.2",
    "decimal.js": "^10.6.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^1.16.0",
    "moti": "^0.30.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.74.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "tamagui": "^2.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
