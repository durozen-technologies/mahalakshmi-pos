{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "5.0",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@haroldtran/react-native-thermal-printer": [
        "./src/types/haroldtran-react-native-thermal-printer"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
